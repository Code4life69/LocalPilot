{
  "app_name": "LocalPilot",
  "enable_gui": true,
  "enable_cli_thread_with_gui": false,
  "active_model_role": "main",
  "active_operating_profile": "reliable_stack",
  "active_performance_profile": "rtx3060_balanced",
  "logs_dir": "logs",
  "memory_dir": "memory",
  "workspace_dir": "workspace",
  "screenshots_dir": "workspace/screenshots",
  "ui": {
    "theme": "dark"
  },
  "ollama": {
    "auto_start_server": true,
    "startup_wait_seconds": 8
  },
  "lmstudio": {
    "host": "http://localhost:1234/v1",
    "timeout_seconds": 120,
    "text_model": "qwen2.5-coder-14b-instruct",
    "agent_planner_model": "qwen2.5-coder-14b-instruct",
    "vision_model": "qwen3-vl-8b-instruct",
    "review_model": "qwen3.5-27b",
    "planner_timeout_seconds": 120,
    "planner_context_length": 16384,
    "planner_minimum_context_length": 8192,
    "planner_recommended_context_length": 16384,
    "planner_max_concurrent_predictions": 1,
    "screenshot_dir": "logs/screenshots"
  },
  "model_lifecycle": {
    "enabled": true,
    "unload_previous_heavy_role": true,
    "keep_lightweight_roles_loaded": true,
    "heavy_roles": [
      "main",
      "coder",
      "vision",
      "quality_slow"
    ]
  },
  "git_sync": {
    "enabled": true,
    "push_on_startup": true,
    "push_on_shutdown": true,
    "commit_message_prefix": "LocalPilot autosync"
  },
  "desktop_guard": {
    "show_overlay": true,
    "title": "LocalPilot Is Using Your PC",
    "message": "Please do not touch your mouse or keyboard until this action is finished.",
    "footer": "LocalPilot will remove this notice as soon as it is safe again."
  },
  "page_understanding": {
    "confidence_threshold": 0.85
  },
  "approvals": {
    "shell_requires_confirmation": true,
    "desktop_requires_confirmation": true,
    "overwrite_requires_confirmation": true
  },
  "professional_build": {
    "enabled": true,
    "max_passes": 3,
    "allow_web_research": true,
    "require_acceptance_checklist": true,
    "stop_on_failed_verification": true,
    "launch_verification_enabled": true,
    "launch_timeout_seconds": 8
  }
}
