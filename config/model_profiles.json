{
  "ollama": {
    "host": "http://127.0.0.1:11434",
    "timeout_seconds": 90
  },
  "default_role": "main",
  "main": {
    "model": "qwen3:8b",
    "num_ctx": 4096,
    "temperature": 0.35,
    "description": "Default fast reasoning and planning model"
  },
  "coder": {
    "model": "qwen2.5-coder:14b-instruct-q3_K_M",
    "fallback_model": "qwen2.5-coder:7b",
    "num_ctx": 4096,
    "temperature": 0.2,
    "description": "Coding, app generation, code repair, project editing"
  },
  "coder_fallback": {
    "model": "qwen2.5-coder:7b",
    "num_ctx": 4096,
    "temperature": 0.2,
    "description": "Fallback coding model when the main coder model is unavailable"
  },
  "vision": {
    "model": "qwen2.5vl:7b",
    "num_ctx": 4096,
    "temperature": 0.1,
    "description": "Screenshot and image understanding"
  },
  "router": {
    "model": "granite3.3:2b",
    "num_ctx": 2048,
    "temperature": 0,
    "description": "Fast intent classification and routing"
  },
  "embedding": {
    "model": "nomic-embed-text",
    "description": "Local embeddings for future memory search"
  },
  "quality_slow": {
    "model": "qwen3:30b",
    "num_ctx": 4096,
    "temperature": 0.3,
    "description": "Optional slow high-quality reasoning mode"
  },
  "reasoning_slow": {
    "model": "deepseek-r1:14b-qwen-distill-q4_K_M",
    "num_ctx": 4096,
    "temperature": 0.25,
    "description": "Optional slow reasoning cross-check"
  },
  "general_fallback": {
    "model": "llama3.1:8b",
    "num_ctx": 4096,
    "temperature": 0.3,
    "description": "Optional stable fallback general model"
  },
  "gemma4_fast": {
    "model": "gemma4:e4b",
    "num_ctx": 4096,
    "temperature": 0.2,
    "description": "Optional fast Gemma 4 multimodal/general comparison model"
  },
  "gemma4_quality": {
    "model": "gemma4:latest",
    "num_ctx": 4096,
    "temperature": 0.25,
    "description": "Optional higher-quality Gemma 4 comparison model if it runs well"
  }
}
